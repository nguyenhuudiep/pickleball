{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Backend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "Start Frontend",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "isBackground": true
    },
    {
      "label": "Start All (No Docker)",
      "dependsOn": ["Start Backend", "Start Frontend"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Install Dependencies",
      "type": "shell",
      "command": "Set-Location backend; npm install; Set-Location ..\\frontend; npm install",
      "presentation": {
        "reveal": "always"
      }
    },
    {
      "label": "Start All With Docker",
      "type": "shell",
      "command": "docker-compose",
      "args": ["up"],
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "always"
      },
      "isBackground": true
    }
  ]
}
